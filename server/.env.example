# Configuración del servidor
# -----------------------------------------------------------------------------
# Copiar este archivo a `.env` y reemplazar los valores antes de levantar el
# backend. NO commitear el `.env` real (queda en .gitignore).

# Entorno: development | production
NODE_ENV=development

# Puerto en el que escucha el servidor Express
PORT=3000

# -----------------------------------------------------------------------------
# Base de datos MySQL
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=liga_basquet

# -----------------------------------------------------------------------------
# Autenticación
# -----------------------------------------------------------------------------
# Cadena criptográfica usada para firmar los JWT. Cambiar por un valor robusto
# en producción (mínimo 32 caracteres aleatorios).
JWT_SECRET=cambiar_este_secreto_por_uno_seguro_de_al_menos_32_caracteres

# Credenciales del administrador inicial creado por `npm run seed`.
# Si no se proveen, el seed usa los defaults (admin / adminpassword) y emite
# una advertencia. Cambiar SIEMPRE en producción.
ADMIN_USER=admin
ADMIN_PASSWORD=adminpassword

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Lista de orígenes permitidos, separados por coma. Sin espacios.
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# Seed (opcional — todos tienen default razonable)
# -----------------------------------------------------------------------------
# LIGA_NAME=Liga de Basquet Juvenil
# LIGA_TEMPORADA=1C 2026
# LIGA_DESCRIPCION=Liga oficial TPO
